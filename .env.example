APP_NAME=Портал трансляций боулинг-клуба
ENVIRONMENT=production
SECRET_KEY=change-this-secret
POSTGRES_DB=bowling
POSTGRES_USER=bowling
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql+psycopg://bowling:change-this-db-password@postgres:5432/bowling
PUBLIC_BASE_URL=http://localhost
NGINX_HLS_BASE_URL=http://localhost/hls
OME_RTMP_BASE_URL=rtmp://localhost:1935/app
OME_API_URL=http://ovenmediaengine:8081
OME_API_ACCESS_TOKEN=ome-access-token
DEFAULT_ARCHIVE_DEPTH_DAYS=14
DEFAULT_PLAYBACK_TYPE=hls
ARCHIVE_ROOT=/opt/bowling-portal/media/archive
ACCESS_TOKEN_TTL_SECONDS=900
HTTP_PORT=80
HTTPS_PORT=443
OME_RTMP_PORT=1935
OME_API_PORT=8081
OME_ORIGIN_PORT=3333
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
